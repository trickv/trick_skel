#!/bin/bash
# Find the first usable SSH agent socket in /tmp with keys available.
# Diagnostics go to stderr; the winning socket path goes to stdout.

MY_UID=$(id -u)

human_age() {
    local seconds=$1
    local days=$((seconds / 86400))
    local hours=$(( (seconds % 86400) / 3600 ))
    local mins=$(( (seconds % 3600) / 60 ))
    if [ $days -gt 0 ]; then
        echo "${days}d ${hours}h ago"
    elif [ $hours -gt 0 ]; then
        echo "${hours}h ${mins}m ago"
    else
        echo "${mins}m ago"
    fi
}

now=$(date +%s)

for sock in /tmp/ssh-*/agent.*; do
    [ -S "$sock" ] || continue

    # The PID in agent.N is the sshd session process
    sshd_pid=${sock##*.}

    # Check if the process exists and belongs to us
    if [ -d "/proc/$sshd_pid" ]; then
        sock_uid=$(stat -c %u "/proc/$sshd_pid" 2>/dev/null)
        if [ "$sock_uid" != "$MY_UID" ]; then
            echo "SKIP $sock (pid $sshd_pid belongs to uid $sock_uid, not $MY_UID)" >&2
            continue
        fi
    else
        echo "SKIP $sock (pid $sshd_pid not running)" >&2
        continue
    fi

    # Get the pts from the sshd process args (e.g. "sshd: trick@pts/8")
    pts=$(ps -o args= -p "$sshd_pid" 2>/dev/null | grep -oP 'pts/\d+')

    # Look up source host from `who` for this pts
    source_host=""
    if [ -n "$pts" ]; then
        source_host=$(who | awk -v p="$pts" '$2 == p {gsub(/[()]/, "", $NF); print $NF}')
        # Try reverse DNS if it looks like an IP
        if [[ "$source_host" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
            rdns=$(getent hosts "$source_host" 2>/dev/null | awk '{print $2}')
            if [ -n "$rdns" ]; then
                source_host="$source_host ($rdns)"
            fi
        fi
    fi

    # Session age from socket mtime
    sock_mtime=$(stat -c %Y "$sock" 2>/dev/null)
    age_str=""
    if [ -n "$sock_mtime" ]; then
        age_str=$(human_age $((now - sock_mtime)))
    fi

    label="${pts:-?}"
    [ -n "$source_host" ] && label="$label from $source_host"
    [ -n "$age_str" ] && label="$label, $age_str"

    # Try listing keys
    output=$(SSH_AUTH_SOCK="$sock" ssh-add -l 2>&1)
    rc=$?
    if [ $rc -eq 0 ]; then
        nkeys=$(echo "$output" | wc -l)
        echo "FOUND $sock [$label] ${nkeys} key(s):" >&2
        echo "$output" | sed 's/^/  /' >&2
        echo "$sock"
        exit 0
    elif [ $rc -eq 1 ]; then
        echo "SKIP $sock [$label] agent running but no keys" >&2
    else
        echo "SKIP $sock [$label] could not connect: $output" >&2
    fi
done

echo "ERROR: no agent with keys found" >&2
exit 1
