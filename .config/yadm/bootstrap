#!/usr/bin/env bash

set -u

# Make trick_skel utilities (e.g. strdate) available to bootstrap.d scripts,
# which run in a non-login shell where .bash_profile_trick_skel isn't sourced.
export PATH="$HOME/bin/trick_skel:$HOME/bin:$PATH"

### Deal with scripts in bootstrap.d (used to be install.d)
scriptdir=$HOME/.yadm/bootstrap.d/
for script in $(find $scriptdir -type f -perm -u+x | sort); do
    echo "Bootstrap executing: $script"
    $script || echo "$script failed"
done
